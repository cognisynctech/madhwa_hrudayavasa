# ─────────────────────────────────────────────────────────────────────
# Madhwa Hrudaya Vasa — Backend Environment Variables
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# YouTube Data API v3 key
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → Enable "YouTube Data API v3"
# 3. Credentials → Create API Key
# 4. (Optional but recommended) Restrict the key to YouTube Data API v3
YOUTUBE_API_KEY=your_api_key_here

# YouTube channel handle (without @)
# Channel URL: https://www.youtube.com/@Madhwahrudayavasa
CHANNEL_HANDLE=Madhwahrudayavasa

# Server port (default: 3001)
PORT=3001
